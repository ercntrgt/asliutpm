# Streamlit secrets şablonu — gerçek dosyayı `secrets.toml` olarak kopyalayın
# (gerçek dosya .gitignore'da; kayıt edilmeyecek).
#
# Lokal kullanım:
#   1. Bu dosyayı `secrets.toml` olarak kopyala (aynı klasör)
#   2. Anthropic API key'inizi yapıştır
#   3. streamlit run app.py
#
# Streamlit Cloud kullanımı:
#   1. https://share.streamlit.io → app settings → Secrets
#   2. Aşağıdaki içeriği TOML olarak yapıştır
#   3. Save

ANTHROPIC_API_KEY = "sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
