# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# Environments
.env
.venv/
env/

# Data — büyük dosyalar git'e gitmesin
data/raw/*
data/processed/*
data/grid/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/grid/.gitkeep
!data/external/.gitkeep
!data/raw/konyaalti_imar_tum_veri.xlsx

# Sonuçlar
results/*.pkl
results/*.npz
# figures/ — tez/online erişim için commit'e dahil edildi (Hafta 24+ sonrası)
# figures/*.png
# figures/*.jpg
# figures/*.pdf
!results/.gitkeep
!figures/.gitkeep

# Streamlit
streamlit_app/.streamlit/secrets.toml
# AMA streamlit_app/data altındaki deploy varlıkları commit'e dahil
!streamlit_app/data/
!streamlit_app/data/*.gpkg
!streamlit_app/data/*.png
!streamlit_app/data/*.json
!streamlit_app/.streamlit/config.toml
!streamlit_app/.streamlit/secrets.toml.example

# osmnx cache
cache/

# IDE
.vscode/
.idea/
*.swp
.claude/

# OS
.DS_Store
Thumbs.db
